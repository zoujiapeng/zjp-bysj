# Application
APP_NAME=学生心理关怀随访与报表系统
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
AUTO_CREATE_TABLES=false
TIMEZONE=Asia/Shanghai

# Initial administrator (created only when the username does not exist)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_NAME=系统管理员

# PostgreSQL used by docker-compose
POSTGRES_DB=student_care
POSTGRES_USER=student_care
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://student_care:change-this-database-password@db:5432/student_care
